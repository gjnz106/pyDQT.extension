<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="DQT BCF Reader"
    Width="1200" Height="780"
    WindowStartupLocation="CenterScreen"
    Background="#FEF8E7"
    FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Card border style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D4B87A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#F0CC88"/>
            <Setter Property="Foreground" Value="#5D4E37"/>
            <Setter Property="BorderBrush" Value="#D4B87A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#D4B87A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ChipInactive" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#D4B87A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F0CC88" CornerRadius="5" Padding="14,10"
                BorderBrush="#D4B87A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DQT BCF Reader" Foreground="#5D4E37"
                               FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="lblSubtitle" Text="No BCF file loaded"
                               Foreground="#7B6F5A" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#5D4E37" CornerRadius="3"
                        Padding="8,4" VerticalAlignment="Center">
                    <TextBlock Text="DQT" Foreground="#F0CC88"
                               FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,8,0,0" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnOpen" Content="Open BCF" Style="{StaticResource BtnPrimary}"
                        Margin="0,0,6,0"/>
                <Button x:Name="btnZoom" Content="Zoom to Issue" Style="{StaticResource BtnSecondary}"
                        Margin="0,0,6,0"/>
                <Button x:Name="btnExport" Content="Export CSV" Style="{StaticResource BtnSecondary}"
                        Margin="0,0,6,0"/>
                <Button x:Name="btnExportBCF" Content="Export BCF (Resolved)" Style="{StaticResource BtnSecondary}"
                        Margin="0,0,6,0"/>
                <Button x:Name="btnExportPDF" Content="Export PDF" Style="{StaticResource BtnSecondary}"
                        Margin="0,0,6,0"/>
                <Border Width="1" Background="#D4B87A" Margin="4,2"/>
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="8,0,8,0"
                           Foreground="#7B6F5A" FontSize="11"/>
                <Button x:Name="btnAll" Content="All" Style="{StaticResource ChipInactive}"/>
                <Button x:Name="btnAdded" Style="{StaticResource ChipInactive}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="●" Foreground="#27AE60" FontSize="13" Margin="0,0,4,0"/>
                        <TextBlock Text="Added" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnRemoved" Style="{StaticResource ChipInactive}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="●" Foreground="#E74C3C" FontSize="13" Margin="0,0,4,0"/>
                        <TextBlock Text="Removed" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnModified" Style="{StaticResource ChipInactive}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="●" Foreground="#F39C12" FontSize="13" Margin="0,0,4,0"/>
                        <TextBlock Text="Modified" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Background="#D4B87A" Margin="4,2"/>
                <Button x:Name="btnUnresolved" Style="{StaticResource ChipInactive}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="○" Foreground="#5D4E37" FontSize="13" Margin="0,0,4,0"/>
                        <TextBlock Text="Unresolved" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnResolved" Style="{StaticResource ChipInactive}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" Foreground="#27AE60" FontSize="13" Margin="0,0,4,0"/>
                        <TextBlock Text="Resolved" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Stats cards -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,3,0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="txtTotal" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="#5D4E37" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total Issues" FontSize="10" Foreground="#7B6F5A"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="2,0,2,0" Background="#E8F5E9">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="txtAdded" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="#27AE60" HorizontalAlignment="Center"/>
                    <TextBlock Text="Added" FontSize="10" Foreground="#27AE60"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="2,0,2,0" Background="#FDEDEC">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="txtRemoved" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="#E74C3C" HorizontalAlignment="Center"/>
                    <TextBlock Text="Removed" FontSize="10" Foreground="#E74C3C"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="3,0,0,0" Background="#FEF5E7">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="txtModified" Text="0" FontSize="22" FontWeight="Bold"
                               Foreground="#F39C12" HorizontalAlignment="Center"/>
                    <TextBlock Text="Modified" FontSize="10" Foreground="#F39C12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Legend -->
        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,8,0,0" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Legend:" FontWeight="SemiBold" Foreground="#5D4E37"
                           VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11"/>
                <TextBlock Text="●" Foreground="#27AE60" FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Text="Added" Foreground="#333333" FontSize="11" VerticalAlignment="Center"
                           Margin="4,0,16,0"/>
                <TextBlock Text="●" Foreground="#E74C3C" FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Text="Removed" Foreground="#333333" FontSize="11" VerticalAlignment="Center"
                           Margin="4,0,16,0"/>
                <TextBlock Text="●" Foreground="#F39C12" FontSize="15" VerticalAlignment="Center"/>
                <TextBlock Text="Modified" Foreground="#333333" FontSize="11" VerticalAlignment="Center"
                           Margin="4,0,16,0"/>
                <Border Width="1" Background="#D4B87A" Margin="4,2,12,2"/>
                <TextBlock Text="Tip: double-click a card to zoom to the element in Revit."
                           Foreground="#7B6F5A" FontSize="10" FontStyle="Italic"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="430"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Padding="8">
                    <WrapPanel x:Name="panelCards" Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Stretch"/>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FEF8E7" Padding="12,8"
                            BorderBrush="#D4B87A" BorderThickness="0,0,0,1"
                            CornerRadius="5,5,0,0">
                        <TextBlock Text="Issue Details" FontWeight="Bold" FontSize="13"
                                   Foreground="#5D4E37"/>
                    </Border>
                    <StackPanel x:Name="panelDetailHeader" Grid.Row="1" Margin="12,10,12,0"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="12,6,12,12">
                        <StackPanel x:Name="panelDetailBody"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="5" Style="{StaticResource CardBorder}" Margin="0,8,0,0" Padding="10,6">
            <TextBlock x:Name="lblStatus" Text="Ready" Foreground="#7B6F5A" FontSize="11"/>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="6" Background="#F5F0E0" CornerRadius="5" Padding="10,6"
                Margin="0,6,0,0" BorderBrush="#D4B87A" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="DQT BCF Reader - Dang Quoc Truong"
                           Foreground="#7B6F5A" FontSize="10"/>
                <TextBlock Grid.Column="1" Text="© DQT 2025" Foreground="#7B6F5A"
                           FontSize="10" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>
